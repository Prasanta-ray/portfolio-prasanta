# ─── GitHub API Token (optional) ───────────────────────────────
# Unauthenticated: 60 requests/hour. With token: 5,000 requests/hour.
# Create a classic PAT at: https://github.com/settings/tokens
# Required scopes: (no scopes needed — public repos only)
GITHUB_TOKEN=

# ─── Site URL ──────────────────────────────────────────────────
# Used for canonical URLs, OG images, sitemap, robots.txt
NEXT_PUBLIC_SITE_URL=https://prasanta.codelithlabs.in
